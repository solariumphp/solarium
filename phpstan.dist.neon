parameters:
    level: 2
    reportIgnoresWithoutComments: true
    paths:
        - examples
        - src
        - tests
    universalObjectCratesClasses:
        - Solarium\Core\Query\DocumentInterface
        - Solarium\Core\Query\Result\QueryType
    ignoreErrors:
        - path: examples/
          rawMessages:
            - Variable $config might not be defined.
            - Variable $adapter might not be defined.
            - Variable $eventDispatcher might not be defined.

